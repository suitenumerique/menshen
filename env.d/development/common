# Django
DJANGO_ALLOWED_HOSTS=*
DJANGO_SECRET_KEY=ThisIsAnExampleKeyForDevPurposeOnly
DJANGO_SETTINGS_MODULE=menshen.settings
DJANGO_SUPERUSER_PASSWORD=admin

# Logging
# Set to DEBUG level for dev only
LOGGING_LEVEL_HANDLERS_CONSOLE=INFO
LOGGING_LEVEL_LOGGERS_ROOT=INFO
LOGGING_LEVEL_LOGGERS_APP=INFO

# Python
PYTHONPATH=/app

# Menshen settings
# Backend url
MENSHEN_BASE_URL="http://localhost:8072"

# OIDC
OIDC_OP_AUTHORIZATION_ENDPOINT=http://localhost:8083/realms/menshen/protocol/openid-connect/auth
OIDC_OP_URL=http://localhost:8083/realms/menshen
OIDC_OP_INTROSPECTION_ENDPOINT=http://nginx:8083/realms/menshen/protocol/openid-connect/token/introspect
OIDC_RS_CLIENT_ID=client_id
OIDC_RS_CLIENT_SECRET=client_secret

# Token exchange
TOKEN_EXCHANGE_ENABLED=True

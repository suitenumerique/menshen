# Django
DJANGO_ALLOWED_HOSTS=*
DJANGO_SECRET_KEY=ThisIsAnExampleKeyForDevPurposeOnly
DJANGO_SETTINGS_MODULE=menshen.settings
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_USERNAME=admin

# Logging
# Set to DEBUG level for dev only
LOGGING_LEVEL_HANDLERS_CONSOLE=INFO
LOGGING_LEVEL_LOGGERS_ROOT=INFO
LOGGING_LEVEL_LOGGERS_APP=DEBUG

# Python
PYTHONPATH=/app

# Menshen settings
# Backend url
MENSHEN_BASE_URL="http://localhost:8072"

# OIDC
OIDC_OP_URL=http://localhost:8080/realms/menshen
OIDC_OP_INTROSPECTION_ENDPOINT=http://keycloak:8080/realms/menshen/protocol/openid-connect/token/introspect
OIDC_RS_CLIENT_ID=menshen
OIDC_RS_CLIENT_SECRET=ThisIsAnExampleKeyForDevPurposeOnly

# Token exchange
TOKEN_EXCHANGE_DEMO_SOURCE_CLIENT_ID=source
TOKEN_EXCHANGE_DEMO_SOURCE_CLIENT_SECRET=source_secret
TOKEN_EXCHANGE_DEMO_TARGET_CLIENT_ID=target
TOKEN_EXCHANGE_DEMO_TARGET_CLIENT_SECRET=target_secret
